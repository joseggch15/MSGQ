# Configuracion de MSGQ — copia este archivo a `.env` o exporta las variables.
# Sin MSGQ_TOKEN, la app arranca automaticamente en modo demo (simulador).

# Endpoint GraphQL del tenant Newmont Merian.
MSGQ_ENDPOINT=https://merian.veridapt.io/graphql

# Site id de Merian (confirmado por introspeccion). Vacio = auto-descubrir.
MSGQ_SITE_ID=1

# Token de API. Se envia como:  Authorization: Token token=<MSGQ_TOKEN>
MSGQ_TOKEN=

# Intervalo de polling en segundos (10-30 recomendado).
MSGQ_POLL_SECONDS=20

# Forzar modo demo (1/true) aunque haya token.
MSGQ_DEMO=

# Ruta del archivo SQLite de la replica local.
MSGQ_DB_PATH=

# Verificacion TLS (1/true por defecto). Poner 0 solo en entornos de prueba.
MSGQ_VERIFY_TLS=1
